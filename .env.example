# ============================================================
# KAIZEN PROJECT'S IA — Variables de Entorno
# ============================================================
# Copia este archivo a .env.local y completa tus propias keys
# ============================================================

# --- SUPABASE (gratuito) ---
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...tu-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...tu-service-role-key

# --- GOOGLE GEMINI (gratuito) ---
GEMINI_API_KEY=AIza...tu-gemini-api-key

# --- OPENROUTER (fallback gratuito) ---
OPENROUTER_API_KEY=sk-or-...tu-openrouter-key

# --- SENTRY (monitoreo gratuito) ---
NEXT_PUBLIC_SENTRY_DSN=https://...@.../...

# --- POSTHOG (analytics gratuito) ---
NEXT_PUBLIC_POSTHOG_KEY=phc_...tu-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- GROQ (LLM alternativo rápido) ---
GROQ_API_KEY=gsk_...tu-groq-key

# --- RESEND (emails gratuitos) ---
RESEND_API_KEY=re_...tu-resend-key

# --- CLOUDFLARE R2 (storage gratuito) ---
R2_ACCESS_KEY_ID=...tu-access-key
R2_SECRET_ACCESS_KEY=...tu-secret-key
R2_BUCKET_NAME=kaizen-documents
R2_ENDPOINT=https://...r2.cloudflarestorage.com

# --- HUGGING FACE (modelos open source) ---
HUGGINGFACE_API_TOKEN=hf_...tu-huggingface-token

# --- UPSTASH (Redis caché gratuito) ---
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...tu-upstash-token

# --- FIRECRAWL (web scraping gratuito) ---
FIRECRAWL_API_KEY=fc-...tu-firecrawl-key

# --- VERCEL (para CI/CD - no en .env.local, sino en GitHub Secrets) ---
# VERCEL_TOKEN=vcp_...
# VERCEL_ORG_ID=...
# VERCEL_PROJECT_ID=...
